# انسخ هذا الملف إلى .env واملأ القيم بقيم قوية

# سرّ توقيع رموز الدخول (JWT) — سلسلة عشوائية طويلة
JWT_SECRET=ضع_سراً_عشوائياً_طويلاً_هنا

# رمز الإدارة (بديل بدائي لتوليد المفاتيح عبر API)
ADMIN_TOKEN=ضع_رمز_إدارة_قوياً_هنا

# حساب لوحة الأدمن (يُنشأ تلقائياً عند الإقلاع) — للدخول على /admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ضع_كلمة_مرور_قوية_للمشرف

# منفذ الخادم
PORT=8080

# ===== قاعدة بيانات PostgreSQL =====
# الخيار 1: رابط اتصال واحد (يوفّره Coolify عادةً عند ربط خدمة Postgres)
DATABASE_URL=postgres://cognita:CHANGE_ME@db:5432/cognita

# الخيار 2 (بدل DATABASE_URL): متغيّرات منفصلة
# PGHOST=db
# PGPORT=5432
# PGUSER=cognita
# PGPASSWORD=CHANGE_ME
# PGDATABASE=cognita

# اجعلها true إذا كان اتصال Postgres يتطلّب SSL (مزوّدات مُدارة)
PGSSL=false

# ===== إشعارات البريد (اختيارية) =====
# عند ضبطها تُرسل الفواتير ومفاتيح التفعيل تلقائياً للعملاء. اتركها فارغة لتعطيل البريد دون أي خطأ.
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=apikey_or_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Cognita <no-reply@dalilai.net>
# SMTP_SECURE=false   # اجعلها true للمنفذ 465
