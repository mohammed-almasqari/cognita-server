# انسخ هذا الملف إلى .env واملأ القيم بقيم قوية

# سرّ توقيع رموز الدخول (JWT) — سلسلة عشوائية طويلة
JWT_SECRET=ضع_سراً_عشوائياً_طويلاً_هنا

# رمز الإدارة لتوليد المفاتيح وإدارة الطلبات
ADMIN_TOKEN=ضع_رمز_إدارة_قوياً_هنا

# منفذ الخادم
PORT=8080

# ===== قاعدة بيانات PostgreSQL =====
# الخيار 1: رابط اتصال واحد (يوفّره Coolify عادةً عند ربط خدمة Postgres)
DATABASE_URL=postgres://cognita:CHANGE_ME@db:5432/cognita

# الخيار 2 (بدل DATABASE_URL): متغيّرات منفصلة
# PGHOST=db
# PGPORT=5432
# PGUSER=cognita
# PGPASSWORD=CHANGE_ME
# PGDATABASE=cognita

# اجعلها true إذا كان اتصال Postgres يتطلّب SSL (مزوّدات مُدارة)
PGSSL=false
